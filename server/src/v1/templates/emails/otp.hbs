<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body {
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background-color: #f0f7ff;
      margin: 0;
      padding: 0;
    }
    .wrapper {
      padding: 40px 20px;
      display: flex;
      justify-content: center;
    }
    .card {
      background: #ffffff;
      border-radius: 16px;
      border: 1px solid #bae0fd;
      box-shadow: 0 4px 6px -1px rgba(2, 132, 199, 0.1), 0 2px 4px -2px rgba(2, 132, 199, 0.06);
      max-width: 450px;
      width: 100%;
      margin: 0 auto;
      overflow: hidden;
    }
    .header {
      background-color: #075985;
      padding: 25px;
      text-align: center;
    }
    .logo {
      font-size: 24px;
      font-weight: 800;
      color: #ffffff;
      letter-spacing: -0.025em;
    }
    .body {
      padding: 30px;
      color: #0c4a6e;
      text-align: center;
    }
    h2 {
      margin-top: 0;
      font-size: 20px;
      color: #075985;
      font-weight: 700;
    }
    p {
      line-height: 1.6;
      font-size: 15px;
      color: #0f172a;
    }
    .otp-container {
      margin: 30px auto;
      background: #e0effe;
      border: 1px solid #bae0fd;
      border-radius: 12px;
      padding: 20px;
      max-width: 280px;
    }
    .otp-code {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 36px;
      font-weight: 800;
      letter-spacing: 6px;
      color: #075985;
      margin: 0;
    }
    .footer {
      background-color: #f8fafc;
      padding: 20px 30px;
      border-top: 1px solid #e2e8f0;
      font-size: 12px;
      color: #64748b;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="header">
        <span class="logo">RecApp Portal Security</span>
      </div>
      <div class="body">
        <h2>Security Verification Code</h2>
        <p>Use the following 6-digit code to complete your two-factor login verification:</p>
        
        <div class="otp-container">
          <div class="otp-code">{{code}}</div>
        </div>
        
        <p style="color: #60646C; font-size: 14px; margin-top: 20px;">This code is valid for 5 minutes. Do not share this code with anyone.</p>
      </div>
      <div class="footer">
        If you did not request this code, please ignore this email or contact support.
      </div>
    </div>
  </div>
</body>
</html>
