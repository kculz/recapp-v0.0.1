<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body {
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background-color: #f0f9ff;
      margin: 0;
      padding: 0;
    }
    .wrapper {
      padding: 40px 20px;
      display: flex;
      justify-content: center;
    }
    .card {
      background: #ffffff;
      border-radius: 16px;
      border: 1px solid #bae6fd;
      box-shadow: 0 4px 6px -1px rgba(14, 165, 233, 0.1), 0 2px 4px -2px rgba(14, 165, 233, 0.06);
      max-width: 500px;
      width: 100%;
      margin: 0 auto;
      overflow: hidden;
    }
    .header {
      background-color: #075985;
      padding: 30px;
      text-align: center;
    }
    .logo {
      font-size: 28px;
      font-weight: 800;
      color: #ffffff;
      letter-spacing: -0.025em;
    }
    .body {
      padding: 30px;
      color: #0c4a6e;
    }
    h2 {
      margin-top: 0;
      font-size: 20px;
      color: #075985;
      font-weight: 700;
    }
    p {
      line-height: 1.6;
      font-size: 15px;
      color: #0f172a;
    }
    .button-container {
      text-align: center;
      margin: 30px 0;
    }
    .btn {
      display: inline-block;
      padding: 12px 28px;
      background-color: #0ea5e9;
      color: #ffffff !important;
      text-decoration: none;
      border-radius: 10px;
      font-weight: 700;
      font-size: 15px;
      box-shadow: 0 10px 15px -3px rgba(14, 165, 233, 0.3);
    }
    .code-container {
      margin: 20px 0;
      background: #f0f9ff;
      border: 1px dashed #7dd3fc;
      border-radius: 8px;
      padding: 15px;
      text-align: center;
    }
    .code {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 14px;
      color: #0369a1;
      font-weight: 600;
      word-break: break-all;
    }
    .footer {
      background-color: #f8fafc;
      padding: 20px 30px;
      border-top: 1px solid #e2e8f0;
      font-size: 12px;
      color: #64748b;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="header">
        <span class="logo">RecApp Portal</span>
      </div>
      <div class="body">
        <h2>Hello {{name}},</h2>
        <p>You have been invited to join the Rehabilitation & Counseling Client Portal (RecApp).</p>
        <p>Please click the button below to set up your password and activate your account:</p>
        
        <div class="button-container">
          <a href="{{activationLink}}" class="btn">Activate Account</a>
        </div>
        
        <p>Or manually paste this code in your app activation page:</p>
        <div class="code-container">
          <span class="code">{{token}}</span>
        </div>
      </div>
      <div class="footer">
        This is an automated invitation link. Valid for 48 hours.
      </div>
    </div>
  </div>
</body>
</html>
